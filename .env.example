OPENAI_API_KEY=your-openai-api-key
SUPABASE_DB_URL=postgresql://user:password@host:5432/dbname

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

MAX_CHUNKS_PER_DOC=2
POLICY_QA_MAX_CHUNKS_PER_DOC=2
INCIDENT_SUMMARY_MAX_CHUNKS_PER_DOC=2
ESCALATION_GUIDANCE_MAX_CHUNKS_PER_DOC=2

POLICY_QA_CANDIDATE_LIMIT=25
INCIDENT_SUMMARY_CANDIDATE_LIMIT=30
ESCALATION_GUIDANCE_CANDIDATE_LIMIT=15

SECTION_IN_QUERY_BOOST=0.10
QUERY_IN_SECTION_BOOST=0.06
SECTION_OVERLAP_MULT=1.3
SECTION_HEADER_BOOST=0.00
